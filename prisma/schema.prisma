// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// USER & WORKSPACE
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  // Mot de passe hashe pour l'authentification Credentials (NextAuth).
  passwordHash  String?
  emailVerified DateTime?
  image         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   WorkspaceMember[]
  // Actions commerciales creees par cet utilisateur.
  createdClientActions ClientAction[] @relation("ClientActionCreatedBy")
  // Actions assignees a cet utilisateur (to-do commercial personnel).
  assignedClientActions ClientAction[] @relation("ClientActionAssignedTo")
  // Notes clients ecrites par cet utilisateur.
  clientNotes    ClientNote[] @relation("ClientNoteAuthor")
  // Factures creees par cet utilisateur (traçabilite interne).
  createdInvoices Invoice[] @relation("InvoiceCreatedBy")
  // Documents importes par cet utilisateur.
  uploadedDocuments Document[] @relation("DocumentUploadedBy")
  // Generations IA lancees par cet utilisateur.
  aiGenerations  AiGeneration[] @relation("AiGenerationCreatedBy")
  // Historique des changements de statut client effectues par cet utilisateur.
  clientStatusChanges ClientStatusHistory[] @relation("ClientStatusChangedBy")
  // Historique des changements de statut projet effectues par cet utilisateur.
  projectStatusChanges ProjectStatusHistory[] @relation("ProjectStatusChangedBy")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]

  clients   Client[]
  // Actions rattachees explicitement au workspace (isolement multi-tenant fort).
  clientActions ClientAction[]
  // Notes clients rattachees explicitement au workspace.
  clientNotes ClientNote[]
  // Journal des transitions de statut clients pour analytics/conversion.
  clientStatusHistory ClientStatusHistory[]
  projects  Project[]
  // Journal des transitions de statut projets pour analytics.
  projectStatusHistory ProjectStatusHistory[]
  invoices  Invoice[]
  // Lignes de facture rattachees explicitement au workspace.
  invoiceItems InvoiceItem[]
  documents Document[]
  aiGenerations AiGeneration[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())

  role        WorkspaceRole @default(MEMBER)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

//////////////////////////////////////////////////////
// CLIENT & PROSPECTION
//////////////////////////////////////////////////////

model Client {
  id               String            @id @default(cuid())

  firstName        String?
  lastName         String?
  fullName         String

  email            String?
  phone            String?
  company          String?
  jobTitle         String?
  website          String?

  // Partie prospection
  status           ClientStatus      @default(PROSPECT) // Statut du client dans le pipeline de vente
  priority         ClientPriority    @default(MEDIUM) // Priorité du client pour les relances et actions commerciales
  source           ClientSource?      // Source : d'ou vient le client (Instagram, LinkedIn, Email, Referral, Website, Discord, Other)
  budgetEstimated  Float?

  lastContactAt    DateTime?
  nextFollowUpAt   DateTime? // Date de la prochaine relance prévu avec le client

  notes            String?
  tags             String[]

  workspaceId      String
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  actions          ClientAction[]
  projects         Project[]
  invoices         Invoice[]
  documents        Document[]
  clientNotes      ClientNote[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@index([nextFollowUpAt])
  // Optimise la vue "clients a relancer" par workspace + statut + date.
  @@index([workspaceId, status, nextFollowUpAt])
  // Optimise les listes par priorite dans un workspace.
  @@index([workspaceId, priority])
  aiGenerations AiGeneration[]
  // Historique des transitions de statut de ce client.
  statusHistory ClientStatusHistory[]
}

model ClientAction {
  id          String              @id @default(cuid())

  type        ClientActionType  // Type d'action (appel, email, relance, réunion, proposition, autre)
  status      ClientActionStatus  @default(TODO) // Statut de l'action (à faire, faite, annulée)

  title       String // Titre de l'action (ex: "Appeler pour relance", "Envoyer proposition", "Réunion de découverte")
  description String? // Description de l'action (ex: "Appeler pour relance", "Envoyer proposition", "Réunion de découverte")

  dueDate     DateTime? // Date d'échéance de l'action
  doneAt      DateTime? // Date de réalisation de l'action

  // Ajout direct du workspace pour simplifier filtrage securise et analytics.
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  clientId    String
  client      Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Qui a cree l'action.
  createdById String?
  createdBy   User? @relation("ClientActionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // A qui l'action est assignee.
  assignedToId String?
  assignedTo   User? @relation("ClientActionAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Index de base pour filtrer les actions d'un workspace.
  @@index([workspaceId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  // Optimise les ecrans "actions du jour" et "actions en retard".
  @@index([workspaceId, status, dueDate])
  // Optimise la to-do commerciale par collaborateur.
  @@index([assignedToId, status, dueDate])
}

model ClientNote {
  id          String    @id @default(cuid())
  content     String // Contenu de la note

  // Ajout direct du workspace pour isolation multi-tenant et filtrage rapide.
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Auteur de la note (utile en equipe).
  authorId    String?
  author      User? @relation("ClientNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  // Permet d'epingler une note importante sur le client.
  isPinned    Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Index de base pour filtrer toutes les notes du workspace.
  @@index([workspaceId])
  @@index([clientId])
  // Optimise l'historique des notes d'un client par date.
  @@index([workspaceId, clientId, createdAt])
}

enum ClientStatus {
  PROSPECT // Nouveau lead, pas encore contacté
  CONTACTED // Contact initial établi, en attente de réponse ou de qualification
  QUALIFIED // Lead qualifié, intérêt confirmé, besoin identifié
  PROPOSAL_SENT // Proposition commerciale envoyée, en attente de décision
  NEGOTIATION // En négociation active, discussions en cours sur les termes
  WON // Client gagné, projet confirmé
  LOST // Client perdu, pas de projet
  INACTIVE // Client inactif, pas de contact récent, à requalifier ou archiver
}

enum ClientPriority {
  LOW
  MEDIUM
  HIGH
}

enum ClientSource {
  INSTAGRAM
  LINKEDIN
  EMAIL
  REFERRAL
  WEBSITE
  DISCORD
  OTHER
}

enum ClientActionType {
  CALL // Appel téléphonique
  EMAIL // Email
  FOLLOW_UP // Relance (appel ou email de suivi)
  MEETING // Réunion (physique ou virtuelle)
  PROPOSAL // Proposition commerciale envoyée
  OTHER // Autre type d'action (ex: message LinkedIn, SMS, etc.)
}

enum ClientActionStatus {
  TODO // À faire
  DONE // Fait
  CANCELED // Annulé
}

//////////////////////////////////////////////////////
// PROJECT
//////////////////////////////////////////////////////

model Project {
  id              String         @id @default(cuid())
  name            String
  description     String?

  status          ProjectStatus  @default(PROSPECT)

  pricingType     PricingType    @default(FIXED)
  budgetEstimated Float? // Budget estimé du projet
  budgetFinal     Float? // Budget final du projet
  hourlyRate      Float? // Taux horaire si pricingType est HOURLY

  websiteUrl      String? // Lien vers le site web ou la livraison du projet

  startDate       DateTime? // Date de début du projet
  deadline        DateTime? // Date limite du projet
  completedAt     DateTime? // Date de fin du projet

  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  workspaceId     String
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invoices        Invoice[]
  documents       Document[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([workspaceId])
  @@index([clientId])
  @@index([status])
  // Optimise les vues de pilotage projet par statut + echeance.
  @@index([workspaceId, status, deadline])
  aiGenerations AiGeneration[]
  // Historique des transitions de statut de ce projet.
  statusHistory ProjectStatusHistory[]
}

enum ProjectStatus {
  PROSPECT
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELED
}

enum PricingType {
  FIXED
  HOURLY
}

//////////////////////////////////////////////////////
// FINANCE
//////////////////////////////////////////////////////

model Invoice {
  id            String         @id @default(cuid())
  // Le numero n'est plus unique globalement, mais unique par workspace.
  invoiceNumber String

  status        InvoiceStatus  @default(DRAFT)

  issueDate     DateTime       @default(now())
  dueDate       DateTime? // Date d'échéance de la facture
  paidAt        DateTime? // Date de paiement de la facture

  // Devise explicite pour supporter multi-pays/compta.
  currency      String         @default("EUR")

  // Decimal pour eviter les erreurs d'arrondi monetaires.
  subtotal      Decimal        @db.Decimal(12, 2)
  taxRate       Decimal?       @db.Decimal(5, 2) // Taux de taxe appliqué à la facture (ex: 20 pour 20%)
  taxAmount     Decimal?       @db.Decimal(12, 2) // Montant de la taxe calculé à partir du subtotal et du taxRate
  total         Decimal        @db.Decimal(12, 2) // Montant total de la facture (subtotal + taxAmount)

  notes         String?

  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  clientId      String
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Qui a cree la facture.
  createdById   String?
  createdBy     User? @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  items         InvoiceItem[]
  documents     Document[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([workspaceId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  // Optimise les listes de factures par statut et echeance.
  @@index([workspaceId, status, dueDate])
  // Garantit l'unicite du numero de facture a l'echelle du workspace.
  @@unique([workspaceId, invoiceNumber])
}

model InvoiceItem {
  id          String    @id @default(cuid())
  label       String // Description courte de l'article (ex: "Design de logo", "Développement site web", "Consultation - 2h")
  description String? 
  // Decimal pour precision des quantites et prix.
  quantity    Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  // Permet d'ordonner proprement les lignes sur un PDF/affichage.
  sortOrder   Int       @default(0)

  // Ajout direct du workspace pour isolation multi-tenant.
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Index de base pour filtrer les lignes du workspace.
  @@index([workspaceId])
  @@index([invoiceId])
  // Optimise le chargement des lignes de facture par workspace.
  @@index([workspaceId, invoiceId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELED
}

//////////////////////////////////////////////////////
// DOCUMENTS
//////////////////////////////////////////////////////

model Document {
  id           String           @id @default(cuid())
  name         String
  url          String
  mimeType     String? // Type MIME du document (ex: application/pdf, image/png, etc.)
  size         Int? // Taille du document en octets

  category     DocumentCategory @default(OTHER)

  workspaceId  String
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  clientId     String?
  client       Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)

  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)

  invoiceId    String?
  invoice      Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  // Qui a uploade le document (audit interne).
  uploadedById String?
  uploadedBy   User?            @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([workspaceId])
  @@index([clientId])
  @@index([projectId])
  @@index([invoiceId])
}

enum DocumentCategory {
  CONTRACT
  QUOTE
  INVOICE
  BRIEF
  DELIVERY
  OTHER
}

//////////////////////////////////////////////////////
// IA
//////////////////////////////////////////////////////

model AiGeneration {
  id           String           @id @default(cuid())

  type         AiGenerationType
  prompt       String
  result       String

  // Champs de suivi IA pour pilotage couts/performance.
  provider     String?
  model        String?
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?
  costUsd      Decimal?         @db.Decimal(12, 6)
  // Metadonnees libres (temperature, latency, etc.).
  metadata     Json?

  workspaceId  String
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  clientId     String?
  client       Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)

  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Qui a lance la generation IA.
  createdById  String?
  createdBy    User?            @relation("AiGenerationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt    DateTime         @default(now())

  @@index([workspaceId])
  @@index([type])
  // Optimise les historiques IA recents par workspace.
  @@index([workspaceId, createdAt])
}

enum AiGenerationType {
  CLIENT_EMAIL
  DISCUSSION_SUMMARY
  PRICE_SUGGESTION
}

//////////////////////////////////////////////////////
// STATUS HISTORY (ANALYTICS)
//////////////////////////////////////////////////////

model ClientStatusHistory {
  id          String       @id @default(cuid())

  // Scope tenant de l'evenement (important securite + analytics).
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Transition de pipeline: statut precedent -> nouveau statut.
  fromStatus  ClientStatus?
  toStatus    ClientStatus

  // Qui a declenche le changement.
  changedById String?
  changedBy   User?        @relation("ClientStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  // Note contextuelle sur le changement (raison, decision, etc.).
  note        String?
  changedAt   DateTime     @default(now())

  @@index([workspaceId])
  @@index([clientId])
  @@index([workspaceId, clientId, changedAt])
}

model ProjectStatusHistory {
  id          String        @id @default(cuid())

  // Scope tenant de l'evenement (important securite + analytics).
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Transition de statut projet: precedent -> nouveau.
  fromStatus  ProjectStatus?
  toStatus    ProjectStatus

  // Qui a declenche le changement.
  changedById String?
  changedBy   User?         @relation("ProjectStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  // Note contextuelle sur le changement.
  note        String?
  changedAt   DateTime      @default(now())

  @@index([workspaceId])
  @@index([projectId])
  @@index([workspaceId, projectId, changedAt])
}